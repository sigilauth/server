{
  "name": "@sigilauth/sdk",
  "version": "0.1.0",
  "description": "Node.js SDK for Sigil Auth - PKI-based strong authentication",
  "license": "AGPL-3.0",
  "author": "Sigil Auth Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/sigilauth/server.git",
    "directory": "sdk-node"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test --ext .ts",
    "generate:types": "openapi-typescript ../../api/openapi.yaml --output src/generated/api-types.ts"
  },
  "dependencies": {
    "@noble/curves": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.3.0",
    "eslint": "^8.56.0",
    "openapi-typescript": "^6.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "authentication",
    "pki",
    "hardware-keys",
    "ecdsa",
    "p256",
    "mfa",
    "multi-party-authorization"
  ]
}
