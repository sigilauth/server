{
  "dashboard": {
    "title": "Sigil Operations Overview",
    "tags": ["sigil", "operations"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Auth Success Rate (5m)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(sigil_challenges_total{status=\"verified\"}[5m])) / sum(rate(sigil_challenges_total{status=\"created\"}[5m]))",
            "legendFormat": "Success Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "red"},
                {"value": 0.95, "color": "yellow"},
                {"value": 0.98, "color": "green"}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Challenge Latency p95",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(sigil_challenge_latency_seconds_bucket{phase=\"verify\"}[5m]))",
            "legendFormat": "p95 Latency"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 0.5, "color": "yellow"},
                {"value": 1.0, "color": "red"}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Push Delivery Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(relay_push_delivery_success_total[5m])) / sum(rate(relay_push_total{status=\"sent\"}[5m]))",
            "legendFormat": "Delivery Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "red"},
                {"value": 0.90, "color": "yellow"},
                {"value": 0.98, "color": "green"}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Active Challenges",
        "type": "stat",
        "targets": [
          {
            "expr": "sigil_challenges_active",
            "legendFormat": "Active"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "Error Rate by Endpoint",
        "type": "table",
        "targets": [
          {
            "expr": "sum by (path) (rate(sigil_http_requests_total{status=~\"5..\"}[5m]))",
            "format": "table"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
      },
      {
        "id": 6,
        "title": "Challenge Throughput",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(sigil_challenges_total{status=\"created\"}[5m]))",
            "legendFormat": "Created"
          },
          {
            "expr": "sum(rate(sigil_challenges_total{status=\"verified\"}[5m]))",
            "legendFormat": "Verified"
          },
          {
            "expr": "sum(rate(sigil_challenges_total{status=\"rejected\"}[5m]))",
            "legendFormat": "Rejected"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "req/s"},
          {"format": "short", "show": false}
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
      }
    ]
  }
}
